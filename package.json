{
  "name": "anivest",
  "author": "Anivest",
  "type": "module",
  "scripts": {
    "dev": "run-p db-server:file db:migrate:local dev:*",
    "dev:next": "next dev",
    "dev:spotlight": "npx @spotlightjs/spotlight",
    "db-server:file": "pglite-server -m 100 --db=local.db",
    "db-server:memory": "pglite-server -m 100",
    "db:migrate:local": "dotenv -c -- drizzle-kit migrate",
    "db:migrate": "dotenv -c -- drizzle-kit migrate",
    "db:generate": "drizzle-kit generate",
    "db:seed": "tsx scripts/seed.ts",
    "db:studio": "drizzle-kit studio",
    "build:next": "next build",
    "build-local": "run-p db-server:memory build:next --race",
    "build": "run-s db:migrate build:next",
    "start": "next start",
    "build-stats": "cross-env ANALYZE=true npm run build",
    "clean": "rimraf .next out coverage",
    "lint": "ultracite check --type-aware --type-check",
    "lint:fix": "ultracite fix --type-aware --type-check",
    "check:types": "tsc --noEmit --pretty",
    "check:deps": "knip",
    "check:i18n": "i18n-check -l src/locales -s en -u src -f next-intl",
    "commit": "commit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "storybook": "storybook dev -p 6006",
    "storybook:test": "vitest run --config .storybook/vitest.config.ts",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@arcjet/next": "^1.9.1",
    "@clerk/localizations": "^4.13.4",
    "@clerk/nextjs": "^7.5.19",
    "@hookform/resolvers": "^5.2.2",
    "@logtape/logtape": "^2.2.4",
    "@sentry/nextjs": "^10.66.0",
    "@t3-oss/env-nextjs": "^0.13.11",
    "drizzle-orm": "^0.45.2",
    "next": "^16.2.10",
    "next-intl": "^4.13.2",
    "pg": "^8.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.81.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@chromatic-com/playwright": "^0.14.11",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@commitlint/prompt-cli": "^21.2.0",
    "@commitlint/types": "^21.0.1",
    "@electric-sql/pglite-socket": "^0.2.7",
    "@faker-js/faker": "^10.5.0",
    "@lingual/i18n-check": "^0.9.5",
    "@next/bundle-analyzer": "^16.2.10",
    "@playwright/test": "^1.61.1",
    "@spotlightjs/spotlight": "^4.11.7",
    "@storybook/addon-a11y": "^10.5.2",
    "@storybook/addon-docs": "^10.5.2",
    "@storybook/addon-vitest": "^10.5.2",
    "@storybook/nextjs-vite": "^10.5.2",
    "@swc/helpers": "^0.5.23",
    "@tailwindcss/postcss": "^4.3.3",
    "@types/node": "^25.9.5",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/browser": "^4.1.10",
    "@vitest/browser-playwright": "^4.1.7",
    "@vitest/coverage-v8": "^4.1.7",
    "babel-plugin-react-compiler": "^1.0.0",
    "checkly": "^7.14.0",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "knip": "^6.27.0",
    "lefthook": "^2.1.10",
    "npm-run-all": "^4.1.5",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "oxlint-tsgolint": "^0.24.0",
    "rimraf": "^6.1.3",
    "semantic-release": "^25.0.7",
    "storybook": "^10.4.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "ultracite": "^7.9.4",
    "vitest": "^4.1.7",
    "vitest-browser-react": "^2.2.0"
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      [
        "@semantic-release/commit-analyzer",
        {
          "preset": "conventionalcommits"
        }
      ],
      "@semantic-release/release-notes-generator",
      "@semantic-release/github"
    ]
  },
  "engines": {
    "node": ">=24"
  },
  "allowScripts": {
    "esbuild@0.27.7": true,
    "esbuild@0.18.20": true,
    "esbuild@0.25.12": true,
    "esbuild@0.28.0": true,
    "@clerk/shared@4.13.1": true,
    "@parcel/watcher@2.5.6": true,
    "@sentry/cli@2.58.6": true,
    "@swc/core@1.15.33": true,
    "lefthook@2.1.8": true,
    "sharp@0.34.5": true
  },
  "postcss": {
    "plugins": {
      "@tailwindcss/postcss": {}
    }
  }
}
